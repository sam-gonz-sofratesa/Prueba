generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─── User ────────────────────────────────────────────────────────────────────

model User {
  id                    String   @id @default(auto()) @map("_id") @db.ObjectId
  nombre_apellido       String
  codigo_empleado       String   @unique
  sexo                  String
  tipo_identificacion   String
  numero_identificacion String   @unique
  isActive              Boolean  @default(true)
  passwordHash          String
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@map("users")
}

// ─── Audit Log ───────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  entityName String
  entityId   String?
  action     String
  userId     String?
  before     Json?
  after      Json?
  createdAt  DateTime @default(now())

  @@index([entityName, entityId, createdAt])
  @@map("audit_logs")
}

model AuditLogArchive {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  entityName String
  entityId   String?
  action     String
  userId     String?
  before     Json?
  after      Json?
  createdAt  DateTime

  @@index([entityName, entityId, createdAt])
  @@map("audit_logs_archive")
}
