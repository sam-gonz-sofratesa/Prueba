
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("DATABASE_URL")
}

// ─── User ────────────────────────────────────────────────────────────────────

enum Role {
  ADMIN
  USER
}

model User {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  email        String   @unique
  passwordHash String
  role         Role     @default(USER)
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("users")
}

// ─── Audit Log ───────────────────────────────────────────────────────────────

model AuditLog {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  entityName String
  entityId   String?
  action     String
  userId     String?
  before     Json?
  after      Json?
  createdAt  DateTime @default(now())

  @@index([entityName, entityId, createdAt])
  @@map("audit_logs")
}

model AuditLogArchive {
  id         String   @id @default(auto()) @map("_id") @db.ObjectId
  entityName String
  entityId   String?
  action     String
  userId     String?
  before     Json?
  after      Json?
  createdAt  DateTime

  @@index([entityName, entityId, createdAt])
  @@map("audit_logs_archive")
}
